{
  "name": "manga-library",
  "version": "1.0.1",
  "description": "Local manga and image library manager with Mihon integration",
  "author": "jhyoo575-dotcom",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "generate:icon": "powershell -ExecutionPolicy Bypass -File scripts/generate-icon.ps1",
    "build": "npm run generate:icon && electron-builder",
    "build:mihon": "powershell -ExecutionPolicy Bypass -File scripts/build-mihon-extension.ps1",
    "release:local": "npm run build && npm run build:mihon"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.mangalibrary.app",
    "productName": "Manga Library",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "asar": true
  }
}
